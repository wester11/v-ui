# Core
JWT_SECRET=replace-with-openssl-rand-hex-32
BOOTSTRAP_ADMIN_EMAIL=admin@local
BOOTSTRAP_ADMIN_PASSWORD=changeme
PUBLIC_BASE_URL=https://panel.example.com

# Ports (host side)
PANEL_HTTP_PORT=80
PANEL_HTTPS_PORT=443
WG_PORT=51820
OBFS_PORT=51821

# TLS mode: selfsigned | letsencrypt | none
TLS_MODE=selfsigned
PANEL_DOMAIN=
LE_EMAIL=

LOG_LEVEL=info
AGENT_INSECURE_TLS=false

# Optional local profile agents
AGENT_1_TOKEN=
AGENT_1_NODE_ID=
AGENT_1_SECRET=
AGENT_X_TOKEN=
AGENT_X_NODE_ID=
AGENT_X_SECRET=

