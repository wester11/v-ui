# ── Control plane connection ──────────────────────────────────────────────────
CONTROL_URL=https://YOUR_PANEL_IP_OR_DOMAIN
AGENT_TOKEN=paste-from-panel
NODE_ID=paste-from-panel
SECRET=paste-from-panel

# ── Protocol ──────────────────────────────────────────────────────────────────
AGENT_PROTOCOL=xray

# ── Xray sidecar ─────────────────────────────────────────────────────────────
XRAY_CONTAINER=xray
XRAY_CONFIG=/etc/xray/config.json
XRAY_HEALTH=127.0.0.1:443
HTTP_LISTEN=:7443
