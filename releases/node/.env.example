# ── Control plane connection ──────────────────────────────────────────────────
CONTROL_URL=https://YOUR_PANEL_IP_OR_DOMAIN
AGENT_TOKEN=paste-from-panel
NODE_ID=paste-from-panel
SECRET=paste-from-panel

# ── Protocol: wireguard | amneziawg | xray (default: amneziawg) ──────────────
AGENT_PROTOCOL=amneziawg

# ── WireGuard / AmneziaWG ─────────────────────────────────────────────────────
WG_IFACE=wg0
WG_ADDR=127.0.0.1:51820
OBFS_LISTEN=:51821
HTTP_LISTEN=:7443

# ── AmneziaWG obfuscation params (ignored for plain wireguard) ────────────────
AWG_JC=4
AWG_JMIN=40
AWG_JMAX=70
AWG_S1=0
AWG_S2=0
AWG_H1=1
AWG_H2=2
AWG_H3=3
AWG_H4=4
