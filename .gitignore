# env / secrets
.env
.env.local
.env.bak
*.pem
*.key

# runtime TLS — структура runtime/ остаётся в git через .gitkeep,
# но сами сертификаты/ключи и acme-challenge не коммитим.
runtime/tls/*.pem
runtime/tls/*.key
runtime/acme-www/.well-known/
runtime/agent-ca/*
!runtime/agent-ca/.gitkeep

# build artifacts
backend/bin/
backend/api-bin
agent/bin/
agent/agent-bin

# Go
*.test
*.out
vendor/

# Node
node_modules/
frontend/dist/
frontend/.vite/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# logs
*.log
err.log

# dev-only helper scripts (not part of the project)
scripts/publish-to-github.sh
scripts/branch-setup.sh
scripts/release.sh

# tsconfig build info
frontend/tsconfig.tsbuildinfo

# redundant legacy docs (content merged into README.md)
ARCHITECTURE.md
STRUCTURE.md

# releases mirror — contains copies of source for each git branch
# (tracked, but exclude their own build artifacts)
releases/panel/frontend/node_modules/
releases/panel/frontend/dist/
releases/panel/frontend/tsconfig.tsbuildinfo
releases/panel/backend/bin/
releases/node/agent/bin/
releases/xray/agent/bin/

# temp test files (can't rm from sandbox)
releases/panel/.test_write
releases/panel/README_test.md
releases/panel/test_write.txt
