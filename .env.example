# Используется install.sh — обычно не нужно редактировать вручную.
# При генерации руками:
#   JWT_SECRET=$(openssl rand -hex 32)
#   SECRETBOX_KEY=$(openssl rand -hex 16)         # 16 hex bytes = 32-char string
#   OBFS_PSK=$(openssl rand -hex 32)
#   BOOTSTRAP_ADMIN_PASSWORD=$(openssl rand -base64 24 | tr -dc 'A-Za-z0-9' | head -c16)

JWT_SECRET=replace-with-openssl-rand-hex-32
SECRETBOX_KEY=0123456789abcdef0123456789abcdef
OBFS_PSK=replace-with-openssl-rand-hex-32

BOOTSTRAP_ADMIN_EMAIL=admin@local
BOOTSTRAP_ADMIN_PASSWORD=changeme

# Порты (host-side)
PANEL_HTTP_PORT=80
PANEL_HTTPS_PORT=443
WG_PORT=51820
OBFS_PORT=51821

# TLS-режим: selfsigned (по IP) | letsencrypt (по домену) | none (HTTP-only)
TLS_MODE=selfsigned
PANEL_DOMAIN=
LE_EMAIL=

LOG_LEVEL=info
AGENT_INSECURE_TLS=true
AGENT_1_TOKEN=
